# COPY THIS FILE: to create your .env file for environment variables in development

# Database
DATABASE_URL="postgresql://lifeos:lifeos_dev_password@postgres:5432/lifeos_financial?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev_secret_change_in_production_minimum_32_chars_long"

# Email (Development - using Mailpit)
RESEND_API_KEY="re_fake_key_for_dev" # Not needed with Mailpit
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_FROM="noreply@lifeos.local"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Redis (Future)
REDIS_URL="redis://redis:6379"

# Feature Flags
ENABLE_GAMIFICATION="true"
ENABLE_EMAIL_NOTIFICATIONS="true"